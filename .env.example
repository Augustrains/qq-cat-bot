# ===== NoneBot =====
DRIVER=~fastapi+~httpx+~websockets
HOST=127.0.0.1
PORT=8085

# ===== QQ Bot =====
QQ_IS_SANDBOX=true
QQ_BOTS=[{"id":"your_bot_id","token":"your_bot_token","secret":"your_bot_secret"}]

# ===== DeepSeek =====
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FAST_MODEL=deepseek-chat
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# ===== Claude (Anthropic) — 可选 =====
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6

# ===== Qwen3-TTS (阿里云百炼) — 可选，语音输出需要 =====
DASHSCOPE_API_KEY=sk-your-dashscope-key
QWEN_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
QWEN_TTS_VOICE=Cherry
QWEN_TTS_MODEL=qwen3-tts-flash
